# Copy to .env and fill values. Used by docker-compose and optional for local run.

# PostgreSQL (must match POSTGRES_* in db service)
DB_NAME=iot_reports
DB_USER=postgres
DB_PASSWORD=postgres

# Backend
SECRET_KEY=django-insecure-change-me-in-production
CORS_ORIGINS=http://10.109.25.97:3000

# Frontend — URL that the browser uses to call the API (e.g. from same host or backend URL)
NEXT_PUBLIC_API_BASE_URL=http://10.109.25.97:3000
